rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow RSVP submissions for the birthday event
    match /brians42nd-rsvp/{document} {
      allow read, write: if true; // Allow anyone to read/write RSVPs for now
    }
    
    // Allow booking submissions
    match /bookings/{document} {
      allow read, write: if true; // Allow anyone to read/write bookings for now
    }
    
    // Allow LQ waitlist submissions
    match /lq_waitlist/{document} {
      allow read, write: if true; // Allow anyone to read/write waitlist entries for now
    }
    
    // Allow comments
    match /comments/{document} {
      allow read, write: if true; // Allow anyone to read/write comments for now
    }
    
    // Raffles - public read for active/ended/cooldown/completed; write via backend
    match /raffles/{document} {
      allow read: if true; // Public can read all raffles for now
      allow write: if true; // Admin writes - tighten with auth later
    }
    
    // Raffle entries - write via webhook/backend; admin read
    match /raffle_entries/{document} {
      allow read, write: if true; // Backend writes via service account; tighten with auth later
    }
    
    // Game rooms - multiplayer game state and chat
    match /gameRooms/{roomId} {
      allow read, write: if true; // Multiplayer; tighten with auth if needed
      match /messages/{messageId} {
        allow read, write: if true;
      }
      match /actions/{actionId} {
        allow read, write: if true;
      }
    }
    
    // WebRTC signaling for game room video calls (from LoveQuest implementation)
    match /gameRoomCalls/{callId} {
      allow read, write: if true; // Participants only; tighten with auth if needed
      match /signaling/{doc} {
        allow read, write: if true;
      }
      match /iceCandidates/{candidateId} {
        allow read, write: if true;
      }
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}



